7","fields":{"slug":"/e-commerce/technical-writing/week1/"},"frontmatter":{"title":"컨텍스트 미아가 되어 버렸어요."}}},{"node":{"id":"661efef6-8092-5c61-918b-57bdaf9abfea","fields":{"slug":"/e-commerce/will/two-week/"},"frontmatter":{"title":"요구사항을 설계로 번역하는 과정에서 내린 선택들"}}},{"node":{"id":"d0f81d4a-cb7f-5e50-82da-78533b0d2f39","fields":{"slug":"/e-commerce/technical-writing/week2/"},"frontmatter":{"title":"협업을 위해 요구사항 문서를 어디까지 작성해야 하는가"}}},{"node":{"id":"53d479fc-7faf-5f18-b17d-3cb49b49fa7c","fields":{"slug":"/e-commerce/technical-writing/week4/"},"frontmatter":{"title":"Kafka Consumer 병목의 진짜 원인: 잘못된 토픽 설계와 불필요한 파싱"}}},{"node":{"id":"a8e11972-fb84-536c-9577-6fbf6e02adc7","fields":{"slug":"/e-commerce/technical-writing/week5/"},"frontmatter":{"title":"인덱스도 없이 캐시부터 붙이려 했냐;"}}},{"node":{"id":"4ec02317-f8bb-5fbe-ab48-f131f2dbe748","fields":{"slug":"/e-commerce/technical-writing/week6/"},"frontmatter":{"title":"PG 3초 딜레이로, 회사 문닫게 생겼어요"}}},{"node":{"id":"31392b66-30e4-5958-bf1e-f988c18931b4","fields":{"slug":"/e-commerce/will/seven-week/"},"frontmatter":{"title":"한 가지를 해결하면 반드시 다른 문제가 따라온다"}}},{"node":{"id":"d60e5ee8-6ccc-5ac9-a6e3-258d1ba60463","fields":{"slug":"/e-commerce/technical-writing/week7/"},"frontmatter":{"title":"선착순 쿠폰 100장, 1만 명이 동시에 누르면?"}}},{"node":{"id":"24d59aae-c874-5382-9370-ab3859fb6c06","fields":{"slug":"/books/tailer/"},"frontmatter":{"title":"과학적 관리법을 읽고"}}},{"node":{"id":"12b5bdc6-2e7f-57fb-a0d8-02e6482110a2","fields":{"slug":"/e-commerce/technical-writing/week8/"},"frontmatter":{"title":"주문 버튼 1만 번 눌리면, 대기열 없이 버틸 수 있을까?"}}},{"node":{"id":"9701f344-6443-50e9-b449-9b1e6319a716","fields":{"slug":"/e-commerce/technical-writing/week9/"},"frontmatter":{"title":"오늘의 인기상품, 어제의 인기상품과 어떻게 구분할까?"}}},{"node":{"id":"6fe6e630-fd69-5e95-8e45-f58a5a2e6f60","fields":{"slug":"/e-commerce/will/will10/"},"frontmatter":{"title":"정상 흐름에서 안 보이는 것들"}}},{"node":{"id":"fe0092f1-b065-5ac2-8216-9546d9d34817","fields":{"slug":"/e-commerce/technical-writing/week10/"},"frontmatter":{"title":"누적 데이터로 '이번 주 랭킹'을 만들 수 있을까?"}}},{"node":{"id":"5e86ae6b-313f-5fc4-a5de-0292679b65ac","fields":{"slug":"/company/"},"frontmatter":{"title":"회사 10주년, AI로 다시 보는 사업의 순간들"}}},{"node":{"id":"7a4a72a7-01d8-58d1-9a40-47fff8243373","fields":{"slug":"/company/work/why6/"},"frontmatter":{"title":"큐 거부 0건을 성공이라고 부른 직후, 진짜 답은 Outbox 였습니다"}}},{"node":{"id":"ca8a1491-04f7-539c-a35d-cc2d66ab7fab","fields":{"slug":"/company/work/why4/"},"frontmatter":{"title":"8h 안에 한 번에 끝낸다는 SLA 가정 때문에 같은 사용자가 계속 누락됐어요"}}},{"node":{"id":"b862a2e5-1235-5d75-8535-853790151514","fields":{"slug":"/company/work/why5/"},"frontmatter":{"title":"첫 호출만 5초, warmup이 답인 줄 알았어요"}}},{"node":{"id":"c491d3d9-9939-5f3c-baf3-3f7cad0bb0b8","fields":{"slug":"/company/work/why3/"},"frontmatter":{"title":"에러 메시지가 결함을 다시 트리거하는 루프"}}},{"node":{"id":"a0fd8c37-34a1-5f88-abd0-e14c96fcc7de","fields":{"slug":"/company/work/why2/"},"frontmatter":{"title":"같은 버그가 두 종류 알림으로 보였습니다"}}},{"node":{"id":"36a52b3b-765c-57e1-b498-0d2eefe1a912","fields":{"slug":"/backend/spring/task-rejection-and-virtual-threads/"},"frontmatter":{"title":"5,235건이 사라진 자리, 코드 어느 줄에서 일어났을까요"}}},{"node":{"id":"1053cdd6-e282-518c-8979-5e7088f966e8","fields":{"slug":"/company/work/why1/"},"frontmatter":{"title":"캐시 hit률 100%인데 왜 응답이 느렸을까"}}}]},"previous":{"fields":{"slug":"/frontend/performance/phase6/"},"frontmatter":{"title":"퍼포먼스 최적화 를 향해 - 4부"}},"next":{"fields":{"slug":"/frontend/performance/phase8/"},"frontmatter":{"title":"퍼포먼스 최적화 를 향해 - 6부"}}},"pageContext":{"id":"384772c5-933a-539f-9cd7-812f4480f07e","previousPostId":"6a2d33c9-805c-5071-85b4-08b4c3e19687","nextPostId":"d9a4319c-c01b-543e-8bb4-978e2b6df8f0"}},"staticQueryHashes":[],"slicesMap":{}}