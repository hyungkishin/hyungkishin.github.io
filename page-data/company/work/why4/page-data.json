s":{"fields":{"slug":"/company/work/why5/"},"frontmatter":{"title":"첫 호출만 5초, warmup이 답인 줄 알았어요"}},"next":{"fields":{"slug":"/company/work/why3/"},"frontmatter":{"title":"에러 메시지가 결함을 다시 트리거하는 루프"}}},"pageContext":{"id":"ca8a1491-04f7-539c-a35d-cc2d66ab7fab","previousPostId":"b862a2e5-1235-5d75-8535-853790151514","nextPostId":"c491d3d9-9939-5f3c-baf3-3f7cad0bb0b8"}},"staticQueryHashes":[],"slicesMap":{}}