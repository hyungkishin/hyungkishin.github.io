"24d59aae-c874-5382-9370-ab3859fb6c06","fields":{"slug":"/books/tailer/"},"frontmatter":{"title":"과학적 관리법을 읽고"}}},{"node":{"id":"5077691a-1bb1-5443-aac9-db75c3b13165","fields":{"slug":"/roopers/technical-writing/round8/"},"frontmatter":{"title":"주문 버튼 1만 번 눌리면, 대기열 없이 버틸 수 있을까?"}}},{"node":{"id":"16970746-e889-521a-a0ed-5c90af35b08b","fields":{"slug":"/roopers/technical-writing/round9/"},"frontmatter":{"title":"오늘의 인기상품, 어제의 인기상품과 어떻게 구분할까?"}}},{"node":{"id":"274a0b97-9f98-5522-a10e-3d213e49aefd","fields":{"slug":"/roopers/will/will10/"},"frontmatter":{"title":"정상 흐름에서 안 보이는 것들"}}},{"node":{"id":"65fb68d8-9ef9-5a5c-b91d-a650f9d47273","fields":{"slug":"/roopers/technical-writing/round10/"},"frontmatter":{"title":"누적 데이터로 '이번 주 랭킹'을 만들 수 있을까?"}}},{"node":{"id":"5e86ae6b-313f-5fc4-a5de-0292679b65ac","fields":{"slug":"/company/"},"frontmatter":{"title":"회사 10주년, AI로 다시 보는 사업의 순간들"}}},{"node":{"id":"c491d3d9-9939-5f3c-baf3-3f7cad0bb0b8","fields":{"slug":"/company/work/why3/"},"frontmatter":{"title":"에러 메시지가 결함을 다시 트리거하는 루프"}}},{"node":{"id":"7a4a72a7-01d8-58d1-9a40-47fff8243373","fields":{"slug":"/company/work/why6/"},"frontmatter":{"title":"큐 거부 0건을 성공이라고 부른 직후, 진짜 답은 Outbox 였습니다"}}},{"node":{"id":"b862a2e5-1235-5d75-8535-853790151514","fields":{"slug":"/company/work/why5/"},"frontmatter":{"title":"첫 호출만 5초, warmup이 답인 줄 알았어요"}}},{"node":{"id":"ca8a1491-04f7-539c-a35d-cc2d66ab7fab","fields":{"slug":"/company/work/why4/"},"frontmatter":{"title":"8h 안에 한 번에 끝낸다는 SLA 가정 때문에 같은 사용자가 계속 누락됐어요"}}},{"node":{"id":"1053cdd6-e282-518c-8979-5e7088f966e8","fields":{"slug":"/company/work/why1/"},"frontmatter":{"title":"캐시 hit률 100%인데 왜 응답이 느렸을까"}}},{"node":{"id":"a0fd8c37-34a1-5f88-abd0-e14c96fcc7de","fields":{"slug":"/company/work/why2/"},"frontmatter":{"title":"같은 버그가 두 종류 알림으로 보였습니다"}}},{"node":{"id":"36a52b3b-765c-57e1-b498-0d2eefe1a912","fields":{"slug":"/backend/spring/task-rejection-and-virtual-threads/"},"frontmatter":{"title":"5,235건이 사라진 자리, 코드 어느 줄에서 일어났을까요"}}}]},"previous":{"fields":{"slug":"/company/work/why1/"},"frontmatter":{"title":"캐시 hit률 100%인데 왜 응답이 느렸을까"}},"next":{"fields":{"slug":"/backend/spring/task-rejection-and-virtual-threads/"},"frontmatter":{"title":"5,235건이 사라진 자리, 코드 어느 줄에서 일어났을까요"}}},"pageContext":{"id":"a0fd8c37-34a1-5f88-abd0-e14c96fcc7de","previousPostId":"1053cdd6-e282-518c-8979-5e7088f966e8","nextPostId":"36a52b3b-765c-57e1-b498-0d2eefe1a912"}},"staticQueryHashes":[],"slicesMap":{}}