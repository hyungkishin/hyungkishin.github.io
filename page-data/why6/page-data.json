tter":{"title":"에러 메시지가 사용자를 통해 결함을 다시 트리거한다 — 자가증식 루프"}}},{"node":{"id":"7a4a72a7-01d8-58d1-9a40-47fff8243373","fields":{"slug":"/why6/"},"frontmatter":{"title":"VT로 봉합하고 '큐 거부 0건'을 성공이라고 부른 직후 — 진짜 답은 Outbox"}}},{"node":{"id":"36a52b3b-765c-57e1-b498-0d2eefe1a912","fields":{"slug":"/task-rejection-and-virtual-threads/"},"frontmatter":{"title":"5,235건이 사라진 자리 — TaskRejectedException부터 Virtual Thread까지"}}}]},"previous":{"fields":{"slug":"/why3/"},"frontmatter":{"title":"에러 메시지가 사용자를 통해 결함을 다시 트리거한다 — 자가증식 루프"}},"next":{"fields":{"slug":"/task-rejection-and-virtual-threads/"},"frontmatter":{"title":"5,235건이 사라진 자리 — TaskRejectedException부터 Virtual Thread까지"}}},"pageContext":{"id":"7a4a72a7-01d8-58d1-9a40-47fff8243373","series":null,"previousPostId":"c491d3d9-9939-5f3c-baf3-3f7cad0bb0b8","nextPostId":"36a52b3b-765c-57e1-b498-0d2eefe1a912"}},"staticQueryHashes":[],"slicesMap":{}}